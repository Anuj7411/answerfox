{
  "name": "@answerfox/audit",
  "version": "0.2.0",
  "description": "Audit engine for the Answerfox SEO toolkit. Crawls a target URL, runs the 50-check framework, and reports findings with evidence + fix recommendations.",
  "license": "MIT",
  "author": "Anuj Ojha",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anuj7411/answerfox.git",
    "directory": "packages/audit"
  },
  "homepage": "https://github.com/Anuj7411/answerfox/tree/main/packages/audit#readme",
  "bugs": "https://github.com/Anuj7411/answerfox/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@answerfox/core": "workspace:*",
    "cheerio": "^1.0.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
