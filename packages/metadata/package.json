{
  "name": "@answerable-kit/metadata",
  "version": "0.1.0",
  "description": "Next.js App Router metadata helpers for the Answerable SEO toolkit.",
  "license": "MIT",
  "author": "Anuj Ojha",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anuj7411/answerable.git",
    "directory": "packages/metadata"
  },
  "homepage": "https://github.com/Anuj7411/answerable/tree/main/packages/metadata#readme",
  "bugs": "https://github.com/Anuj7411/answerable/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "@answerable-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
