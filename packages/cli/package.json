{
  "name": "@answerable-kit/cli",
  "version": "0.1.1",
  "description": "The `answerable` command — runs audits, prints reports, explains checks.",
  "license": "MIT",
  "author": "Anuj Ojha",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anuj7411/answerable.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Anuj7411/answerable/tree/main/packages/cli#readme",
  "bugs": "https://github.com/Anuj7411/answerable/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "answerable": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@answerable-kit/audit": "workspace:*",
    "@answerable-kit/core": "workspace:*",
    "@answerable-kit/templates": "workspace:*",
    "@clack/prompts": "^0.9.0",
    "commander": "^13.0.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
