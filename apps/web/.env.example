# Answerfox web app environment variables.
# Copy to `.env.local` and fill in values from your Supabase project.

# --- Supabase ---

# Pooled (transaction-mode) Postgres connection string.
# Used by the app at runtime (query workloads, Edge Functions).
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (transaction mode)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Direct (session-mode) Postgres connection string.
# Used by drizzle-kit for DDL migrations. Bypasses the pooler.
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (direct connection)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.compute.amazonaws.com:5432/postgres"

# Public anon key (safe to expose in browser).
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Service role key (server-only, NEVER expose to browser).
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → service_role secret
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- Observability ---

# PostHog product analytics (optional in local dev, silent no-op when unset).
# Get from: https://us.posthog.com → Project Settings → API keys
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry error tracking (wired in a later PR).
# SENTRY_DSN=""
