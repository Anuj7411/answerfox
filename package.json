{
  "name": "answerfox",
  "version": "0.0.0",
  "private": true,
  "description": "The drop-in SEO toolkit that makes any site answerable by AI search engines.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anuj7411/answerfox.git"
  },
  "license": "MIT",
  "author": "Anuj Ojha",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@answerfox/* --filter=!@answerfox/docs --filter=!@answerfox/example-basic-nextjs",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
